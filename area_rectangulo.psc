Algoritmo area_rectangulo 
	Definir base,altura,area Como Real
	Escribir "ingrese base y altura"
	Esperar 5 segundo 
	Borrar Pantalla
	Escribir "ingrese la base del rectangulo"
	leer base 
	Borrar Pantalla
	Escribir " ingrese altura rectangulo"
	leer altura 
	Borrar Pantalla
	area=base*altura
	Escribir " el area del rectangulo" area ,"centrimetro"
	
	
FinAlgoritmo
