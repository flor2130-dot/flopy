Algoritmo  buscarparimpar
	definir parimapar, resultado Como Real
	escribir"introduce un numero"
	leer num 
	si (num=0) Entonces
		escribir"el num no se par ni impar ya que cero"
	sino 
		si (num mod 2 = 0) entonces 
			escribir"el num es par"
		sino 
			escribir"el num es impar" 
		FinSi
		
	FinSi
	
FinAlgoritmo
