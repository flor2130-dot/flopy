Algoritmo mayor20 
	definir NroDesado Como Real
	Escribir " escriba el numero que desa verificar si es mayor a no a 20" 
	leer NroDesado
	si (NroDesado)>(20) Entonces
		escribir"el numero es mayor a 20",Nordesado 
	sino 
		Escribir " el numero es menor o igual a 20",NroDesado
	FinSi
FinAlgoritmo
